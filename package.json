{
  "name": "evaluacion-personal",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "docker compose -f infra/docker/docker-compose.yml up -d postgres redis && turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^5.20.0",
    "turbo": "^2.1.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}